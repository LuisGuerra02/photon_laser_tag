<script>
    setTimeout(function(){
        document.getElementById('rowM').classList.remove('hide');
        }, 7000);
        setTimeout(function(){
        document.getElementById('submitButton').classList.remove('hide');
        }, 7000);
    const fadeOut = 
    document.querySelector('.splash');
    document.addEventListener('DOMContentLoaded', (timeout)=>
        {setTimeout(()=>
            {fadeOut.classList.add('fade-out');}, 4000)})

    ID = ""
    Name = ""
    function myFunction() 
    {
        count = 1;
        tempID = "";
        tempName = "";
        while(count < 16) // For red team
        {
            tempID = (document.getElementById("playerID" + count).value);
            tempName = (document.getElementById("playerName" + count).value);

            if (tempID == "" || tempName == "")
                break;
            ID = tempID
            Name = tempName
            postInfo()
            count++;
        }

        count = 16;
        tempID = "";
        tempName = "";
        while(count < 31) // For blue team
        {
            tempID = (document.getElementById("playerID" + count).value);
            tempName = (document.getElementById("playerName" + count).value);

            if (tempID == "" || tempName == "")
                break;
            ID = tempID
            Name = tempName
            postInfo()
            count++;
        }
    }

    async function postInfo() {
        // e.preventDefault(); // Supposed to prevent refresh, but breaks the program and doesn't seem to be an issue currently.
        const res = await fetch('http://localhost:3000/',
        {
            method: 'POST',
            headers: {
                "Content-Type": 'application/json'
            },
            body: JSON.stringify ({
                parcel: ID + ',' + Name
            })
        })
    }
</script>